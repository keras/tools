#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = [
#     "pytest",
#     "pyyaml",
# ]
# ///

"""dsb — Run commands in an isolated Docker container.

Features:
  - Builds a shared Docker image (debian:bookworm-slim + mise)
    on first use; subsequent launches reuse the cached image. Pass --rebuild to
    force a rebuild.
  - Uses a named Docker volume (dsb-home) as the container user's home,
    keeping all tool state (.cargo/, .rustup/, .local/share/mise/, etc.)
    in the Docker VM's filesystem — isolated from the host and fast.
  - Overlays every entry found in ~/.config/dsb/home/ as individual bind
    mounts on top of the home volume, so user config (.claude/, .gitconfig,
    .config/mise/, etc.) flows in from the host without polluting it with
    tool state. Override the volume name with DSB_HOME_VOLUME.
  - Mirrors the host working directory path suffix under /workdir so file paths
    stay consistent (e.g. ~/work/myproject -> /workdir/work/myproject).
  - Runs as the host user with libnss-wrapper uid mapping to the
    "sandbox" username, avoiding permission mismatches on mounted volumes.
  - By default, launches inside a tmux session so the terminal can be
    detached/reattached. Pass --no-tmux to run CMD directly.

Command routing (arguments after dsb options are passed as Docker CMD):
  dsb                     -> bash
  dsb -- foo              -> foo           (no leading "-" replaces command)

Options:
  --project <path>   host directory to mount as project (default: CWD)
  --no-project       ephemeral workdir, no host directory mounted
  --rebuild          force a full Docker image rebuild and recreate volumes
  --reset-home       remove and recreate the home volume (wipes all tool state)
  --[no-]tmux        run inside a tmux session (default: --tmux)
  --[no-]tty         allocate a TTY (default: --tty)

Environment:
  DSB_ENV           space-separated list of env var names to forward
                    into the container (e.g. "DATABRICKS_TOKEN GITHUB_TOKEN")

X11 / GUI:
  DISPLAY is forwarded automatically. On macOS, set up XQuartz once:
    1. Install XQuartz, open it, go to Preferences → Security →
       enable "Allow connections from network clients"
    2. Run: xhost + localhost
"""

# development notes:
# run ruff to check formatting and linting:
#   uv run --with ruff ruff check ./dsb
# run pytest to execute tests:
#   uv run ./dsb test


