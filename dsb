class TestResolveMounts:
    """Unit tests for mount resolution."""

    def _cfg(self, tmp_path):
        home = tmp_path / "home"
        cwd = home / "dev" / "myproject"
        cwd.mkdir(parents=True)
        dsb_home = home / ".config" / "dsb" / "home"
        dsb_home.mkdir(parents=True)
        return Config(cwd=cwd, home=home, project=cwd), dsb_home

    def test_dsb_home_entries_mounted_individually(self, tmp_path):
        cfg, dsb_home = self._cfg(tmp_path)
        (dsb_home / ".gitconfig").touch()
        (dsb_home / ".claude").mkdir()

        mounts = resolve_mounts(cfg)
        dsts = [m.dst for m in mounts]
        assert f"{CONTAINER_HOME}/.gitconfig" in dsts
        assert f"{CONTAINER_HOME}/.claude" in dsts

    def test_dsb_home_not_mounted_as_whole(self, tmp_path):
        cfg, _ = self._cfg(tmp_path)
        mounts = resolve_mounts(cfg)
        assert not any(m.dst == CONTAINER_HOME for m in mounts)

    def test_empty_dsb_home_no_overlay_mounts(self, tmp_path):
        cfg, _ = self._cfg(tmp_path)
        mounts = resolve_mounts(cfg)
        overlay = [m for m in mounts if m.dst.startswith(CONTAINER_HOME)]
        assert len(overlay) == 0

    def test_no_project_skips_workdir_mount(self, tmp_path):
        home = tmp_path / "home"
        home.mkdir(parents=True)
        dsb_home = home / ".config" / "dsb" / "home"
        dsb_home.mkdir(parents=True)
        cfg = Config(cwd=home, home=home, project=None)
        mounts = resolve_mounts(cfg)
        workdir_mounts = [m for m in mounts if m.dst.startswith("/workdir/")]
        assert len(workdir_mounts) == 0

    def test_project_mount_present(self, tmp_path):
        cfg, _ = self._cfg(tmp_path)
        mounts = resolve_mounts(cfg)
        project_mounts = [m for m in mounts if m.dst == cfg.workdir]
        assert len(project_mounts) == 1
        assert project_mounts[0].src == str(cfg.project)
        assert project_mounts[0].readonly is False

    def test_config_yaml_mount_tilde_dst(self, tmp_path):
        cfg, _ = self._cfg(tmp_path)
        # Use absolute src so we don't depend on ~ resolving to cfg.home (a tmp path)
        gitconfig = Path.home() / ".gitconfig"
        config_yaml = cfg.home / ".config" / "dsb" / "config.yaml"
        config_yaml.write_text("mount:\n  - ~/.gitconfig:~/.gitconfig\n")

        mounts = resolve_mounts(cfg)
        explicit = [m for m in mounts if m.dst == f"{CONTAINER_HOME}/.gitconfig"]
        assert len(explicit) == 1
        assert explicit[0].src == str(gitconfig)
        assert explicit[0].readonly is False

    def test_config_yaml_mount_absolute_dst(self, tmp_path):
        cfg, _ = self._cfg(tmp_path)
        src = cfg.home / ".ssh"
        src.mkdir()
        config_yaml = cfg.home / ".config" / "dsb" / "config.yaml"
        config_yaml.write_text(f"mount:\n  - {src}:/home/sandbox/.ssh\n")

        mounts = resolve_mounts(cfg)
        explicit = [m for m in mounts if m.dst == "/home/sandbox/.ssh"]
        assert len(explicit) == 1
        assert explicit[0].src == str(src)

    def test_config_yaml_missing_no_extra_mounts(self, tmp_path):
        cfg, _ = self._cfg(tmp_path)
        before = resolve_mounts(cfg)
        # ensure no config.yaml exists
        assert not (cfg.home / ".config" / "dsb" / "config.yaml").exists()
        assert before == resolve_mounts(cfg)

    def test_config_yaml_empty_mount_list(self, tmp_path):
        cfg, _ = self._cfg(tmp_path)
        config_yaml = cfg.home / ".config" / "dsb" / "config.yaml"
        config_yaml.write_text("mount: []\n")
        mounts = resolve_mounts(cfg)
        explicit = [m for m in mounts if m.dst.startswith(CONTAINER_HOME + "/")]
        assert len(explicit) == 0


