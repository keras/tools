CONTAINER_HOME = "/home/sandbox"


@dataclass
class Config:
    """Parsed CLI options and derived paths."""

    cwd: Path
    home: Path
    project: Path | None = None  # None = ephemeral, no project mount
    rebuild: bool = False
    reset_home: bool = False
    verbose: bool = False
    use_mise: bool = True
    use_tmux: bool = True
    use_tty: bool = True
    passthrough_args: list[str] = field(default_factory=list)

    @property
    def image_name(self) -> str:
        return os.environ.get("DSB_IMAGE", "dsb:latest")

    @property
    def workdir(self) -> str:
        """Container working directory — /workdir/… for projects, $HOME for ephemeral."""
        if self.project is None:
            return "/workdir"
        try:
            rel = self.project.relative_to(self.home)
            return f"/workdir/{rel}"
        except ValueError:
            parts = self.project.parts
            return f"/workdir/{'/'.join(parts[-2:])}"

    @property
    def dsb_home(self) -> Path:
        """Dedicated container home directory on the host."""
        return self.home / ".config" / "dsb" / "home"

    @property
    def home_volume(self) -> str:
        return os.environ.get("DSB_HOME_VOLUME", "dsb-home")


# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------


def parse_args(argv: list[str]) -> Config:
    """Parse CLI arguments, passing remainder through to Docker CMD."""
    file_cfg = _load_dsb_config(Path.home())

    parser = argparse.ArgumentParser(
        prog="dsb",
        description="Run Claude Code in an isolated Docker container.",
    )
    project_group = parser.add_mutually_exclusive_group()
    project_group.add_argument(
        "--project",
        default=None,
        metavar="PATH",
        help="host directory to mount as the project (default: CWD)",
    )
    project_group.add_argument(
        "--no-project",
        action="store_true",
        help="ephemeral workdir, no host directory mounted",
    )
    parser.add_argument(
        "--rebuild",
        action="store_true",
        help="force a full Docker image rebuild and recreate volumes",
    )
    parser.add_argument(
        "--reset-home",
        action="store_true",
        help="remove and recreate the home volume (wipes all tool state)",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="print the docker run command before executing",
    )
    parser.add_argument(
        "--mise",
        action=argparse.BooleanOptionalAction,
        default=file_cfg.get("mise", True),
        help="run mise install on startup (default: true)",
    )
    parser.add_argument(
        "--tmux",
        action=argparse.BooleanOptionalAction,
        default=file_cfg.get("tmux", False),
        help="run inside tmux (default: true)",
    )
    parser.add_argument(
        "--tty",
        action=argparse.BooleanOptionalAction,
        default=file_cfg.get("tty", False),
        help="allocate a TTY (default: true)",
    )
    parser.add_argument(
        "rest",
        nargs=argparse.REMAINDER,
        help="arguments passed to Docker CMD (use -- to separate)",
    )

    ns = parser.parse_args(argv)

    # REMAINDER captures the '--' separator if present; strip it
    passthrough = ns.rest
    if passthrough and passthrough[0] == "--":
        passthrough = passthrough[1:]

    if ns.no_project:
        project = None
    elif ns.project:
        project = Path(ns.project).resolve()
    else:
        project = Path.cwd()

    return Config(
        cwd=Path.cwd(),
        home=Path.home(),
        project=project,
        rebuild=ns.rebuild,
        reset_home=ns.reset_home,
        verbose=ns.verbose,
        use_mise=ns.mise,
        use_tmux=ns.tmux,
        use_tty=ns.tty,
        passthrough_args=passthrough,
    )


# ---------------------------------------------------------------------------
# Dockerfile
# ---------------------------------------------------------------------------

DOCKERFILE = r"""
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    git curl gpg \
    tmux zsh gosu libnss-wrapper bash-completion nano \
    podman fuse-overlayfs uidmap \
    build-essential pkg-config libssl-dev \
    libx11-6 libxext6 libxrender1 libxtst6 libxi6 libxcursor1 libx11-xcb1 libxkbcommon-x11-0 \
    sudo \
    && rm -rf /var/lib/apt/lists/* \
    && echo "sandbox ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/sandbox \
    && chmod 0440 /etc/sudoers.d/sandbox

# Rootless Podman configuration
RUN mkdir -p /etc/containers && \
    echo '{"default":[{"type":"insecureAcceptAnything"}]}' \
        > /etc/containers/policy.json && \
    printf '[registries.search]\nregistries = ["docker.io"]\n' \
        > /etc/containers/registries.conf && \
    printf '[storage]\ndriver = "overlay"\n\n[storage.options]\nmount_program = "/usr/bin/fuse-overlayfs"\n' \
        > /etc/containers/storage.conf && \
    printf '[containers]\n# Docker bind-mounts /proc/sys read-only so crun cannot set sysctls.\ndefault_sysctls = []\n# Sharing the outer PID namespace avoids crun needing to mount a new proc\n# inside a nested user+mount namespace, which Docker prevents.\npidns = "host"\n# slirp4netns sets accept_dad before the inner mount namespace is active,\n# hitting the outer read-only /proc/sys; disabling IPv6 skips that sysctl.\nnetwork_cmd_options = ["enable_ipv6=false"]\n' \
        > /etc/containers/containers.conf

# Shell setup
RUN printf '\n[ -f /usr/share/bash-completion/bash_completion ] && . /usr/share/bash-completion/bash_completion\n' \
    >> /etc/bash.bashrc && \
    printf '\neval "$(mise activate bash)"\n' >> /etc/bash.bashrc && \
    printf '\nalias docker=podman\n' >> /etc/bash.bashrc
# profile.d so login shells (bash -lc / su) also get the mise shims in PATH.
# /etc/profile hardcodes a minimal PATH that drops Docker ENV, so this is needed.
RUN printf 'export HOME=/home/sandbox\nexport MISE_DATA_DIR=/home/sandbox/.local/share/mise\nexport MISE_STATE_DIR=/home/sandbox/.local/state/mise\nexport MISE_CACHE_DIR=/home/sandbox/.cache/mise\nexport PATH=/home/sandbox/.local/share/mise/shims:$PATH\n' \
    > /etc/profile.d/mise.sh

# mise
RUN curl -fsSL https://mise.run | MISE_INSTALL_PATH=/usr/local/bin/mise sh

ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV EDITOR=nano

RUN mkdir -p /home/sandbox /workdir && chmod 777 /home/sandbox /workdir

ENV HOME=/home/sandbox
ENV MISE_DATA_DIR=/home/sandbox/.local/share/mise
ENV PATH=/home/sandbox/.local/share/mise/shims:$PATH

# Entrypoint
RUN cat > /entrypoint.sh <<'ENTRYPOINT'
#!/bin/bash

_verbose_run() {
    t0=${EPOCHREALTIME/./}
    "$@"
    rc=$?
    if [ -n "${DSB_VERBOSE}" ]; then
        dt=$(( ${EPOCHREALTIME/./} - t0 ))
        printf '[dsb][%s]: %d.%03ds\n' "$*" "$((dt / 1000000))" "$(( (dt % 1000000) / 1000 ))" >&2
    fi
    return $rc
}

HOST_UID="${HOST_UID:-0}"
HOST_GID="${HOST_GID:-0}"
cp /etc/passwd /tmp/passwd
echo "sandbox:x:${HOST_UID}:${HOST_GID}::/home/sandbox:/bin/bash" >> /tmp/passwd
echo "sandbox:x:${HOST_UID}:${HOST_GID}::/home/sandbox:/bin/bash" >> /etc/passwd
# PAM account validation requires a shadow entry; ! = locked password (fine for NOPASSWD sudo)
echo "sandbox:!:19000:0:99999:7:::" >> /etc/shadow
export NSS_WRAPPER_PASSWD=/tmp/passwd
export NSS_WRAPPER_GROUP=/etc/group
export LD_PRELOAD=$(find /usr/lib -name 'libnss_wrapper.so' | head -1)
# Promote root mount to shared propagation so Podman can propagate mounts
# across its own mount namespaces (Docker defaults to private propagation).
mount --make-rshared /
# subuid/subgid ranges required by rootless Podman for uid mapping
echo "sandbox:100000:65536" >> /etc/subuid
echo "sandbox:100000:65536" >> /etc/subgid
# XDG_RUNTIME_DIR is required by rootless Podman for its socket
export XDG_RUNTIME_DIR="/run/user/${HOST_UID}"
mkdir -p "${XDG_RUNTIME_DIR}"
chmod 700 "${XDG_RUNTIME_DIR}"
chown "${HOST_UID}:${HOST_GID}" "${XDG_RUNTIME_DIR}"
# Fix ownership of home dir
export HOME=/home/sandbox
export MISE_DATA_DIR=/home/sandbox/.local/share/mise
export MISE_STATE_DIR=/home/sandbox/.local/state/mise
export MISE_CACHE_DIR=/home/sandbox/.cache/mise
export PATH="/home/sandbox/.local/share/mise/shims:/home/sandbox/bin:$PATH"
export MISE_YES=1

# Make /proc/sys writable so nested container runtimes (podman, etc.) can
# configure network namespaces they create. Requires SYS_ADMIN + seccomp=unconfined.
mount -o remount,rw /proc/sys 2>/dev/null || true

if [ -n "${DSB_MISE}" ]; then
    _verbose_run gosu "${HOST_UID}:${HOST_GID}" mise install || true
fi
exec gosu "${HOST_UID}:${HOST_GID}" "$@"
ENTRYPOINT
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
""".lstrip()


# ---------------------------------------------------------------------------
# Docker build
# ---------------------------------------------------------------------------


def _build_context_tar() -> bytes:
    """Create an in-memory tar archive with just the Dockerfile.

    Mise tools are installed lazily at container
    start and cached via a named Docker volume.
    """
    buf = io.BytesIO()
    with tarfile.open(fileobj=buf, mode="w") as tar:
        dockerfile_bytes = DOCKERFILE.encode()
        info = tarfile.TarInfo("Dockerfile")
        info.size = len(dockerfile_bytes)
        tar.addfile(info, io.BytesIO(dockerfile_bytes))
    return buf.getvalue()


def image_exists(name: str) -> bool:
    return (
        subprocess.run(
            ["docker", "image", "inspect", name],
            capture_output=True,
        ).returncode
        == 0
    )


def build_image(cfg: Config) -> None:
    print(f"Building {cfg.image_name}...")
    context = _build_context_tar()
    run_kwargs = {}
    if not cfg.verbose:
        run_kwargs["stdout"] = subprocess.DEVNULL
        run_kwargs["stderr"] = subprocess.DEVNULL
    subprocess.run(
        ["docker", "build", "-t", cfg.image_name, "-"],
        input=context,
        check=True,
        **run_kwargs,
    )


