# Relative paths (from ~/.config/dsb) → default file contents.
DSB_DEFAULT_FILES: dict[str, str] = {
    "config.yaml": textwrap.dedent(
        """\
        # dsb configuration — uncomment and edit as needed.
        # See: dsb --help
        #
        # Run inside a tmux session (lets you detach/reattach):
        # tmux: true
        #
        # Allocate a TTY:
        # tty: true
        #
        # Extra bind mounts (~ expands to host home on left, container home on right):
        # mount:
        #   - ~/.ssh:~/.ssh
        """
    ),
    "home/.config/mise/conf.d/tools.toml": textwrap.dedent(
        """\
        # mise tools — list tools you want available in every dsb container.
        # See: https://mise.jdx.dev/configuration.html
        #
        # [tools]
        # node = "lts"
        # python = "latest"
        # rust = "latest"
        # uv = "latest"
        """
    ),
}


def _init_config_dir(home: Path) -> None:
    """Create ~/.config/dsb with default template files if it does not exist."""
    config_dir = home / ".config" / "dsb"
    if config_dir.exists():
        return

    print(f"Initialising default config at {config_dir} …")

    for rel, content in DSB_DEFAULT_FILES.items():
        path = config_dir / rel
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content)


# ---------------------------------------------------------------------------
# Volume mounts
# ---------------------------------------------------------------------------


@dataclass
class Mount:
    """A single Docker bind mount."""

    src: str
    dst: str
    readonly: bool = True

    def to_args(self) -> list[str]:
        spec = f"{self.src}:{self.dst}"
        if self.readonly:
            spec += ":ro"
        return ["-v", spec]


def _load_dsb_config(home: Path) -> dict:
    """Load ~/.config/dsb/config.yaml; return empty dict if absent or empty."""
    path = home / ".config" / "dsb" / "config.yaml"
    if not path.exists():
        return {}
    with path.open() as f:
        return yaml.safe_load(f) or {}


def resolve_mounts(cfg: Config) -> list[Mount]:
    """Build the list of bind mounts for the container."""
    mounts: list[Mount] = []

    # Project directory (--no-project skips this)
    if cfg.project is not None:
        mounts.append(Mount(str(cfg.project), cfg.workdir, readonly=False))

    # Overlay each entry from dsb_home on top of the named home volume.
    # Config (.claude/, .gitconfig, .config/mise/, …) flows in from the host;
    # tool state (.cargo/, .rustup/, .local/) stays in the named volume.
    if cfg.dsb_home.is_dir():
        for entry in sorted(cfg.dsb_home.iterdir()):
            mounts.append(
                Mount(str(entry), f"{CONTAINER_HOME}/{entry.name}", readonly=False)
            )

    # Explicit mounts from ~/.config/dsb/config.yaml
    # Format:  mount: ["~/src:~/dst"]  — ~ in src expands to host home,
    #                                      ~ in dst expands to container home.
    dsb_cfg = _load_dsb_config(cfg.home)
    for entry in dsb_cfg.get("mount", []):
        src_str, dst_str = entry.split(":", 1)
        src = Path(src_str.strip()).expanduser()
        dst = dst_str.strip()
        if dst.startswith("~/"):
            dst = f"{CONTAINER_HOME}/{dst[2:]}"
        elif dst == "~":
            dst = CONTAINER_HOME
        mounts.append(Mount(str(src), dst, readonly=False))

    return mounts


# ---------------------------------------------------------------------------
# Environment forwarding
# ---------------------------------------------------------------------------


def resolve_env(cfg: Config) -> list[tuple[str, str]]:
    """Collect environment variables to pass into the container."""
    env: list[tuple[str, str]] = [
        ("HOST_UID", str(os.getuid())),
        ("HOST_GID", str(os.getgid())),
        ("HOME", CONTAINER_HOME),
        ("SHELL", "/bin/bash"),
        ("TERM", os.environ.get("TERM", "xterm-256color")),
        ("COLORTERM", os.environ.get("COLORTERM", "")),
    ]

    # X11 forwarding: on macOS, Docker Desktop runs in a VM so the host X11
    # socket isn't reachable. Always point at the host via TCP so XQuartz
    # works after: xhost + localhost  (run once in XQuartz terminal)
    host_display = os.environ.get("DISPLAY", "")
    if sys.platform == "darwin" or not host_display or host_display.startswith("/"):
        display = "host.docker.internal:0"
    else:
        display = host_display
    env.append(("DISPLAY", display))

    if cfg.use_mise:
        env.append(("DSB_MISE", "1"))
    if cfg.verbose:
        env.append(("DSB_VERBOSE", "1"))

    # Forward user-specified env vars (DSB_ENV)
    for name in os.environ.get("DSB_ENV", "").split():
        if name in os.environ:
            env.append((name, os.environ[name]))

    return env


# ---------------------------------------------------------------------------
# Docker run
# ---------------------------------------------------------------------------


def _resolve_container_cmd(cfg: Config) -> list[str]:
    """Determine the command the container should run.

    Applies the same routing as the old entrypoint:
      - No args          -> bash
      - Otherwise        -> passthrough as-is

    When tmux is enabled, wraps the cmd in a tmux session.
    """
    args = cfg.passthrough_args

    if not args:
        inner = ["bash"]
    else:
        inner = args

    if cfg.use_tmux:
        post_command = "exec bash" if inner[0] not in ("bash", "zsh") else ""
        quoted = " ".join(shlex.quote(a) for a in inner)
        return ["tmux", "new-session", "-s", "main", f"{quoted}; {post_command}"]

    return inner


def build_run_command(
    cfg: Config, mounts: list[Mount], env: list[tuple[str, str]]
) -> list[str]:
    """Assemble the full 'docker run' command."""
    cmd: list[str] = ["docker", "run", "-i"]
    if cfg.use_tty:
        cmd.append("-t")
    cmd.append("--rm")
    # Required for rootless Podman inside the container:
    #   /dev/fuse          — fuse-overlayfs storage driver
    #   /dev/net/tun       — slirp4netns user-mode network helper
    #   seccomp=unconfined — allows clone(CLONE_NEWUSER) and related syscalls
    #   apparmor=unconfined — Docker's AppArmor profile blocks mount(2) even
    #                         with SYS_ADMIN; crun needs to mount proc inside
    #                         the inner container's mount namespace
    #   SYS_ADMIN          — lets setuid newuidmap write to /proc/<pid>/uid_map
    #                         in the parent user namespace (CAP_SETUID alone is
    #                         not sufficient when nested inside Docker)
    #   NET_ADMIN          — allows writing to /proc/sys/net/* in network
    #                         namespaces that podman creates for inner containers
    cmd.extend(
        [
            "--device",
            "/dev/fuse",
            "--device",
            "/dev/net/tun",
            "--security-opt",
            "seccomp=unconfined",
            "--security-opt",
            "apparmor=unconfined",
            "--cap-add",
            "SYS_ADMIN",
            "--cap-add",
            "NET_ADMIN",
        ]
    )

    # Named volume as home base — tool state (.cargo, .rustup, .local, …)
    # stays in the Docker VM, off the host filesystem.
    cmd.extend(["-v", f"{cfg.home_volume}:{CONTAINER_HOME}"])

    for mount in mounts:
        cmd.extend(mount.to_args())

    cmd.extend(["-w", cfg.workdir])

    for key, val in env:
        cmd.extend(["-e", f"{key}={val}"])

    cmd.append(cfg.image_name)

    cmd.extend(_resolve_container_cmd(cfg))
    return cmd


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main(args) -> None:
    _init_config_dir(Path.home())
    cfg = parse_args(args)

    if cfg.reset_home:
        print(f"Removing home volume {cfg.home_volume}...")
        subprocess.run(
            ["docker", "volume", "rm", "-f", cfg.home_volume],
            check=False,
            capture_output=True,
        )

    if cfg.rebuild or not image_exists(cfg.image_name):
        build_image(cfg)

    mounts = resolve_mounts(cfg)
    env = resolve_env(cfg)
    cmd = build_run_command(cfg, mounts, env)

    if cfg.verbose:
        import shlex

        print(shlex.join(cmd), file=sys.stderr)

    os.execvp(cmd[0], cmd)


class TestParseArgs:
    def test_all_flags(self):
        args = [
            "--rebuild",
            "--no-tmux",
            "-v",
            "--",
            "echo",
            "hello",
        ]
        cfg = parse_args(args)
        assert cfg.rebuild is True
        assert cfg.use_tmux is False
        assert cfg.verbose is True
        assert cfg.passthrough_args == ["echo", "hello"]

    def test_config_yaml_sets_tmux_tty_defaults(self, tmp_path, monkeypatch):
        home = tmp_path / "home"
        config_dir = home / ".config" / "dsb"
        config_dir.mkdir(parents=True)
        (config_dir / "config.yaml").write_text("tmux: false\ntty: false\n")
        monkeypatch.setattr(Path, "home", staticmethod(lambda: home))
        monkeypatch.setattr(Path, "cwd", staticmethod(lambda: home))

        cfg = parse_args([])
        assert cfg.use_tmux is False
        assert cfg.use_tty is False

    def test_cli_flag_overrides_config_yaml(self, tmp_path, monkeypatch):
        home = tmp_path / "home"
        config_dir = home / ".config" / "dsb"
        config_dir.mkdir(parents=True)
        (config_dir / "config.yaml").write_text("tmux: false\ntty: false\n")
        monkeypatch.setattr(Path, "home", staticmethod(lambda: home))
        monkeypatch.setattr(Path, "cwd", staticmethod(lambda: home))

        cfg = parse_args(["--tmux", "--tty"])
        assert cfg.use_tmux is True
        assert cfg.use_tty is True


@pytest.fixture
def sandbox(tmp_path, monkeypatch):
    """Set up a fake home + project directory tree and patch away side effects."""
    home = tmp_path / "home"
    project = home / "dev" / "myproject"
    project.mkdir(parents=True)

    # Dedicated container home
    dsb_home = home / ".config" / "dsb" / "home"
    dsb_home.mkdir(parents=True)

    monkeypatch.setattr(Path, "cwd", staticmethod(lambda: project))
    monkeypatch.setattr(Path, "home", staticmethod(lambda: home))
    monkeypatch.setattr("os.getuid", lambda: 1000)
    monkeypatch.setattr("os.getgid", lambda: 1000)

    # Capture the docker command instead of exec-ing
    captured = {}

    def fake_execvp(file, args):
        captured["cmd"] = args

    monkeypatch.setattr("os.execvp", fake_execvp)

    # Skip actual Docker interactions
    monkeypatch.setattr(
        "subprocess.run",
        lambda *a, **kw: type("R", (), {"returncode": 0})(),  # image exists
    )

    return types.SimpleNamespace(
        home=home, project=project, dsb_home=dsb_home, captured=captured
    )


class TestMainIntegration:
    """Full integration tests that call main() against a temp directory."""

    def test_home_volume_mounted(self, sandbox):
        main(["--no-tmux", "--no-tty"])

        cmd = " ".join(sandbox.captured["cmd"])
        assert f"dsb-home:{CONTAINER_HOME}" in cmd

    def test_dsb_home_entries_overlaid_individually(self, sandbox):
        (sandbox.dsb_home / ".gitconfig").write_text("[user]\n  name = Test\n")
        (sandbox.dsb_home / ".claude").mkdir()

        main(["--no-tmux", "--no-tty"])

        cmd = " ".join(sandbox.captured["cmd"])
        assert f"{sandbox.dsb_home}/.gitconfig:{CONTAINER_HOME}/.gitconfig" in cmd
        assert f"{sandbox.dsb_home}/.claude:{CONTAINER_HOME}/.claude" in cmd

    def test_project_dir_mounted(self, sandbox):
        main(["--no-tmux", "--no-tty"])

        cmd = " ".join(sandbox.captured["cmd"])
        assert f"{sandbox.project}:/workdir/dev/myproject" in cmd

