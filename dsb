@docker
class TestDockerRuntime:
    """Tests that call dsb.py as a subprocess, actually building
    and running the Docker container. Validates entrypoint, profile.d, shim
    resolution, and home mounting against the real mise runtime."""

    def _run(self, docker_env, args, timeout=120):
        """Run dsb.py as a subprocess in the test project dir."""
        env = os.environ.copy()
        env["HOME"] = str(docker_env.home)
        env["DSB_IMAGE"] = docker_env.image
        env["DSB_HOME_VOLUME"] = docker_env.home_volume
        env.pop("DSB_ENV", None)
        return subprocess.run(
            [sys.executable, SCRIPT, "--no-tmux", "--no-tty", *args],
            cwd=docker_env.project,
            env=env,
            capture_output=True,
            text=True,
            timeout=timeout,
        )

    def test_uv_available_in_login_shell(self, docker_env):
        r = self._run(docker_env, ["--", "bash", "-lc", "uv --version"])
        assert r.returncode == 0
        assert "uv" in r.stdout

    def test_uv_available_via_direct_invocation(self, docker_env):
        r = self._run(docker_env, ["--", "uv", "--version"])
        assert r.returncode == 0
        assert "uv" in r.stdout

    def test_home_correct_in_login_shell(self, docker_env):
        r = self._run(docker_env, ["--", "bash", "-lc", "echo $HOME"])
        assert r.returncode == 0
        assert r.stdout.strip() == CONTAINER_HOME

    def test_home_correct_via_entrypoint(self, docker_env):
        r = self._run(docker_env, ["--", "bash", "-c", "echo $HOME"])
        assert r.returncode == 0
        assert r.stdout.strip() == CONTAINER_HOME

    def test_mise_sees_home_config(self, docker_env):
        r = self._run(docker_env, ["--", "bash", "-lc", "mise list 2>&1"])
        assert r.returncode == 0
        assert "uv" in r.stdout

    def test_mise_shims_in_path(self, docker_env):
        r = self._run(docker_env, ["--", "bash", "-lc", "echo $PATH"])
        assert "mise/shims" in r.stdout

    def test_no_permission_errors(self, docker_env):
        r = self._run(docker_env, ["--", "uv", "--version"])
        assert "Permission denied" not in r.stderr

    def test_cargo_available_in_login_shell(self, docker_env):
        r = self._run(docker_env, ["--", "bash", "-lc", "cargo --version"])
        assert r.returncode == 0
        assert "cargo" in r.stdout

    def test_exit_code_propagation(self, docker_env):
        """Non-zero exit code from the command should propagate through the container."""
        r = self._run(docker_env, ["--", "bash", "-c", "exit 42"])
        assert r.returncode == 42

    def test_no_project_workdir_writable(self, docker_env):
        """--no-project should land in a writable /workdir."""
        r = self._run(
            docker_env,
            [
                "--no-project",
                "--",
                "bash",
                "-c",
                "date > /workdir/test && cat /workdir/test",
            ],
        )
        assert r.returncode == 0
        assert r.stdout.strip() != ""


